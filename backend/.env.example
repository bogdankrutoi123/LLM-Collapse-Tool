# Environment Configuration
ENVIRONMENT=development

# Database Configuration
# Local dev (backend on host): localhost
DATABASE_URL=postgresql://llm_user:llm_password@localhost:5432/llm_detector
# Docker Compose (backend in container): use host "db"
# DATABASE_URL=postgresql://llm_user:llm_password@db:5432/llm_detector
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=llm_password
POSTGRES_DB=llm_detector

# Application Settings
APP_NAME="LLM Collapse Detector"
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1

# Security Settings
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENFORCE_HTTPS=False
ENCRYPT_DATA=False
DATA_ENCRYPTION_KEY=

# Registration / Bootstrap
# When False, /auth/register returns 403; admins must create users via /users.
PUBLIC_REGISTRATION_ENABLED=False
# One-shot token used by POST /auth/bootstrap-admin to create the first admin.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BOOTSTRAP_ADMIN_TOKEN=

# Auth Cookies (HttpOnly access + refresh tokens)
ACCESS_COOKIE_NAME=llm_access_token
REFRESH_COOKIE_NAME=llm_refresh_token
# Set COOKIE_SECURE=True behind HTTPS in production
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS Settings
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8000","http://127.0.0.1:8000"]

# Email Configuration
# Dev with docker-compose mailcatcher:
# SMTP_HOST=mailcatcher
# SMTP_PORT=1025
# SMTP_USER=dev@local
# SMTP_PASSWORD=
# SMTP_STARTTLS=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@llmdetector.com
SMTP_STARTTLS=True

# Hugging Face (for gated models)
HUGGINGFACE_HUB_TOKEN=
BENCHMARK_MAX_REMOTE_MODEL_SIZE_GB=8
BENCHMARK_MAX_REMOTE_WEIGHT_SHARDS=4

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Application Limits
MAX_PROMPT_LENGTH=10000
MAX_OUTPUT_LENGTH=50000
MAX_BATCH_SIZE=100
MAX_TOKENS_TO_STORE=1000

# Metrics Configuration
DEFAULT_ALERT_THRESHOLD_ENTROPY=0.5
DEFAULT_ALERT_THRESHOLD_KL_DIVERGENCE=0.3
DEFAULT_ALERT_THRESHOLD_LENGTH_DEVIATION=2.0

# File Storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=100

# Evaluation Pipeline
EVAL_MAX_PROMPTS_PER_JOB=2000
EVAL_MODEL_LOCK_TTL_SECONDS=7200
EVAL_DEFAULT_TOP_K_TOKEN_PROBS=10
EVAL_MAX_TOP_K_TOKEN_PROBS=50
